{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest --run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "firebase-admin": "^13.4.0",
    "firebase": "workspace:*",
    "hono": "^4.12.7",
    "types": "workspace:*"
  },
  "@/types/*": [
    "../../packages/types/src/*"
  ],
  "@/firebase/*": [
    "../../packages/firebase/*"
  ],
  "devDependencies": {
    "@types/node": "^20.11.17",
    "fast-check": "^4.6.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
